# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Velluto Autopilot
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-me-32-chars-minimum-secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://velluto:velluto@localhost:5432/velluto_autopilot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

# ─── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_SHOP_NAME=velluto.myshopify.com
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=...
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-10

# ─── Meta Ads ─────────────────────────────────────────────────────────────────
META_APP_ID=...
META_APP_SECRET=...
META_ACCESS_TOKEN=EAAxxxxx
META_AD_ACCOUNT_ID=act_XXXXXXXXX

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_RECIPIENT_NUMBER=+491234567890

# ─── WhatsApp (Twilio — alternative) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Google (Search Console) ──────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/secrets/gsc-service-account.json
GSC_SITE_URL=https://velluto.com/

# ─── Microsoft Clarity ────────────────────────────────────────────────────────
CLARITY_PROJECT_ID=xxxxxxxxxx
CLARITY_API_TOKEN=...

# ─── Email Marketing (SendGrid) ───────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM_ADDRESS=hello@velluto.com
EMAIL_FROM_NAME=Velluto Eyewear

# ─── OpenAI (DALL-E creative generation) ─────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx

# ─── Business Targets ────────────────────────────────────────────────────────
DAILY_SALES_TARGET=7
MONTHLY_SALES_TARGET=200

# ─── Scheduling ───────────────────────────────────────────────────────────────
DAILY_REPORT_TIME=08:30
DAILY_REPORT_TIMEZONE=Europe/Berlin

# ─── Autonomy Thresholds ──────────────────────────────────────────────────────
MAX_AUTO_BUDGET_CHANGE_PCT=0.10
MAX_AUTO_DISCOUNT_PCT=0.00

# ─── Competitor Monitoring ────────────────────────────────────────────────────
COMPETITOR_URLS=["https://oakley.com","https://rudy-project.com","https://100percent.com"]

# ─── Metrics ─────────────────────────────────────────────────────────────────
METRICS_PORT=9090
